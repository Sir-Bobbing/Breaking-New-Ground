
<ruleset>
	<rule stacksize="16">
		<or>
			<condition>id = minecraft:potion</condition>
			<condition>id = minecraft:splash_potion</condition>
			<condition>id = minecraft:lingering_potion</condition>
		</or>
	</rule>
	<rule stacksize="256">
		<condition>stacksize gt 1</condition>
	</rule>
</ruleset>
